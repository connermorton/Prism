# ── Anthropic ────────────────────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Supabase ─────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
#
# These names work in both Vercel serverless functions (runtime) AND the Vite
# browser build. Set all three in your Vercel project environment variables.
#
# Project URL (safe to expose to browser)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key (safe to expose to browser)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Service role key — server-side only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
